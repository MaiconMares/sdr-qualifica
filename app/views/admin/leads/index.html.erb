<div class="min-h-screen bg-gradient-to-br from-blue-900 via-purple-900 to-indigo-900">
  <div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">Gerenciar Leads</h1>
        <p class="text-white/70">Visualize e gerencie todos os leads</p>
      </div>
      <div class="flex space-x-3">
        <%= button_to "Redistribuir Leads", redistribute_admin_leads_path, 
            method: :post,
            data: { turbo_confirm: "Tem certeza? Isso redistribuirá todos os leads pendentes." },
            class: "bg-purple-500 hover:bg-purple-600 text-white font-semibold px-6 py-3 rounded-xl transition-colors" %>
        <%= link_to "Kanban", admin_kanban_path, class: "bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-xl transition-colors" %>
      </div>
    </div>

    <!-- Filters -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20 mb-8">
      <%= form_with url: admin_leads_path, method: :get, local: true do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <label class="block text-white/70 text-sm font-medium mb-2">Status</label>
            <select name="status" class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              <option value="">Todos</option>
              <% Lead.statuses.each do |status| %>
                <option value="<%= status %>" <%= params[:status] == status ? 'selected' : '' %>><%= status.humanize %></option>
              <% end %>
            </select>
          </div>
          <div>
            <label class="block text-white/70 text-sm font-medium mb-2">SDR</label>
            <select name="sdr_id" class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              <option value="">Todos</option>
              <% @sdrs.each do |sdr| %>
                <option value="<%= sdr.id %>" <%= params[:sdr_id] == sdr.id.to_s ? 'selected' : '' %>><%= sdr.name %></option>
              <% end %>
            </select>
          </div>
          <div>
            <label class="block text-white/70 text-sm font-medium mb-2">Faixa de Faturamento</label>
            <select name="revenue_range_id" class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              <option value="">Todas</option>
              <% @revenue_ranges.each do |range| %>
                <option value="<%= range.id %>" <%= params[:revenue_range_id] == range.id.to_s ? 'selected' : '' %>><%= range.name %></option>
              <% end %>
            </select>
          </div>
          <div>
            <label class="block text-white/70 text-sm font-medium mb-2">Cidade</label>
            <%= text_field_tag :city, params[:city], class: "w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Buscar por cidade" %>
          </div>
        </div>
        <div class="mt-4 flex justify-end">
          <%= f.submit "Filtrar", class: "bg-blue-500 hover:bg-blue-600 text-white font-semibold px-6 py-2 rounded-xl transition-colors" %>
          <%= link_to "Limpar", admin_leads_path, class: "ml-3 text-white/70 hover:text-white" %>
        </div>
      <% end %>
    </div>

    <!-- Leads Table -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl border border-white/20 overflow-hidden">
      <table class="w-full">
        <thead class="bg-white/5">
          <tr>
            <th class="text-left text-white/70 font-medium px-6 py-4">Empresa</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Contato</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Telefone</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">SDR</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Status</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Faturamento</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
          <% @leads.each do |lead| %>
            <tr class="hover:bg-white/5 transition-colors">
              <td class="text-white px-6 py-4 font-medium"><%= lead.company_name %></td>
              <td class="text-white/70 px-6 py-4"><%= lead.contact_name %></td>
              <td class="text-white/70 px-6 py-4"><%= lead.phone %></td>
              <td class="text-white/70 px-6 py-4"><%= lead.current_sdr&.name || "-" %></td>
              <td class="px-6 py-4">
                <span class="px-3 py-1 rounded-full text-sm font-medium <%= lead_status_class(lead.status) %>">
                  <%= lead.status.humanize %>
                </span>
              </td>
              <td class="text-white/70 px-6 py-4"><%= lead.revenue_range&.name || "-" %></td>
              <td class="px-6 py-4">
                <%= link_to "Ver", admin_lead_path(lead), class: "text-blue-400 hover:text-blue-300 text-sm font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <!-- Pagination -->
      <% if @pagy.pages > 1 %>
        <div class="px-6 py-4 bg-white/5 border-t border-white/10">
          <%= pagy_nav(@pagy) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
