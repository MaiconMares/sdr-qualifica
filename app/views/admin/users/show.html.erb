<div class="min-h-screen bg-gradient-to-br from-blue-900 via-purple-900 to-indigo-900">
  <div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2"><%= @user.name %></h1>
        <p class="text-white/70"><%= @user.email %> • <%= @user.role.upcase %></p>
      </div>
      <div class="flex space-x-3">
        <%= link_to "Editar", edit_admin_user_path(@user), class: "bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-xl transition-colors" %>
        <%= link_to "Voltar", admin_users_path, class: "bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-xl transition-colors" %>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
        <div class="text-white/60 text-sm font-medium mb-2">Total de Chamadas</div>
        <div class="text-white text-3xl font-bold"><%= @user.call_sessions.finished.count %></div>
      </div>
      <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
        <div class="text-white/60 text-sm font-medium mb-2">Tempo Médio por Chamada</div>
        <div class="text-white text-3xl font-bold"><%= format_duration(@user_stats[:average_call_duration]) %></div>
      </div>
      <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
        <div class="text-white/60 text-sm font-medium mb-2">Tempo Total de Pausas</div>
        <div class="text-white text-3xl font-bold"><%= format_duration(@user_stats[:total_pause_duration]) %></div>
      </div>
      <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
        <div class="text-white/60 text-sm font-medium mb-2">Leads Pendentes</div>
        <div class="text-white text-3xl font-bold"><%= @user.pending_leads_count %></div>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
      <h2 class="text-xl font-bold text-white mb-4">Atividade Recente</h2>
      <div class="space-y-3">
        <% @user.audit_logs.order(created_at: :desc).limit(10).each do |log| %>
          <div class="flex items-center justify-between py-3 border-b border-white/10 last:border-0">
            <div>
              <div class="text-white font-medium"><%= log.action_label %></div>
              <div class="text-white/50 text-sm"><%= time_ago_in_words(log.created_at) %> atrás</div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
