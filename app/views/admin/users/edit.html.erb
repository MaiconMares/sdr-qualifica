<div class="min-h-screen bg-gradient-to-br from-blue-900 via-purple-900 to-indigo-900">
  <div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white mb-2">Editar Usuário</h1>
      <p class="text-white/70">Atualize as informações do usuário</p>
    </div>

    <!-- Form -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-8 border border-white/20 max-w-2xl">
      <%= form_with model: [:admin, @user], local: true do |f| %>
        <div class="space-y-6">
          <div>
            <%= f.label :name, "Nome", class: "block text-white/70 text-sm font-medium mb-2" %>
            <%= f.text_field :name, class: "w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>

          <div>
            <%= f.label :email, "Email", class: "block text-white/70 text-sm font-medium mb-2" %>
            <%= f.email_field :email, class: "w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>

          <div>
            <%= f.label :password, "Nova Senha (deixe em branco para manter)", class: "block text-white/70 text-sm font-medium mb-2" %>
            <%= f.password_field :password, class: "w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirmação de Nova Senha", class: "block text-white/70 text-sm font-medium mb-2" %>
            <%= f.password_field :password_confirmation, class: "w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>

          <div>
            <%= f.label :role, "Função", class: "block text-white/70 text-sm font-medium mb-2" %>
            <div class="grid grid-cols-2 gap-4">
              <label class="flex items-center p-4 rounded-xl border-2 border-white/20 hover:border-blue-500 cursor-pointer transition-colors">
                <%= f.radio_button :role, :sdr, class: "w-4 h-4 text-blue-600" %>
                <span class="ml-3 text-white">SDR</span>
              </label>
              <label class="flex items-center p-4 rounded-xl border-2 border-white/20 hover:border-blue-500 cursor-pointer transition-colors">
                <%= f.radio_button :role, :admin, class: "w-4 h-4 text-blue-600" %>
                <span class="ml-3 text-white">Administrador</span>
              </label>
            </div>
          </div>

          <div>
            <%= f.label :session_timeout_minutes, "Timeout de Sessão (minutos)", class: "block text-white/70 text-sm font-medium mb-2" %>
            <%= f.number_field :session_timeout_minutes, class: "w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-blue-500 focus:border-transparent", min: 1, max: 1440 %>
          </div>

          <div class="flex items-center">
            <%= f.check_box :active, class: "w-4 h-4 text-blue-600 rounded" %>
            <%= f.label :active, "Usuário ativo", class: "ml-3 text-white" %>
          </div>

          <div class="flex space-x-4 pt-4">
            <%= f.submit "Atualizar Usuário", class: "flex-1 bg-blue-500 hover:bg-blue-600 text-white font-semibold py-3 px-6 rounded-xl transition-colors" %>
            <%= link_to "Cancelar", admin_user_path(@user), class: "flex-1 bg-white/10 hover:bg-white/20 text-white font-semibold py-3 px-6 rounded-xl transition-colors text-center" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
