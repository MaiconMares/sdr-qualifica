<div class="min-h-screen bg-gradient-to-br from-blue-900 via-purple-900 to-indigo-900">
  <div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">Gerenciar Usuários</h1>
        <p class="text-white/70">Adicione e gerencie SDRs e administradores</p>
      </div>
      <%= link_to "Novo Usuário", new_admin_user_path, class: "bg-blue-500 hover:bg-blue-600 text-white font-semibold px-6 py-3 rounded-xl transition-colors" %>
    </div>

    <!-- Users Table -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl border border-white/20 overflow-hidden">
      <table class="w-full">
        <thead class="bg-white/5">
          <tr>
            <th class="text-left text-white/70 font-medium px-6 py-4">Nome</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Email</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Função</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Status</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Leads Pendentes</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
          <% @users.each do |user| %>
            <tr class="hover:bg-white/5 transition-colors">
              <td class="text-white px-6 py-4 font-medium"><%= user.name %></td>
              <td class="text-white/70 px-6 py-4"><%= user.email %></td>
              <td class="px-6 py-4">
                <span class="px-3 py-1 rounded-full text-sm font-medium <%= user.admin? ? 'bg-purple-500/20 text-purple-300' : 'bg-blue-500/20 text-blue-300' %>">
                  <%= user.role.upcase %>
                </span>
              </td>
              <td class="px-6 py-4">
                <% if user.active? %>
                  <span class="px-3 py-1 rounded-full text-sm font-medium bg-green-500/20 text-green-300">Ativo</span>
                <% else %>
                  <span class="px-3 py-1 rounded-full text-sm font-medium bg-red-500/20 text-red-300">Inativo</span>
                <% end %>
              </td>
              <td class="text-white/70 px-6 py-4"><%= user.pending_leads_count %></td>
              <td class="px-6 py-4">
                <div class="flex space-x-2">
                  <%= link_to "Ver", admin_user_path(user), class: "text-blue-400 hover:text-blue-300 text-sm font-medium" %>
                  <%= link_to "Editar", edit_admin_user_path(user), class: "text-white/70 hover:text-white text-sm font-medium" %>
                  <% if user.active? %>
                    <%= link_to "Desativar", deactivate_admin_user_path(user), 
                        data: { turbo_method: :patch, turbo_confirm: "Tem certeza?" },
                        class: "text-red-400 hover:text-red-300 text-sm font-medium" %>
                  <% else %>
                    <%= link_to "Ativar", activate_admin_user_path(user), 
                        data: { turbo_method: :patch },
                        class: "text-green-400 hover:text-green-300 text-sm font-medium" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <!-- Pagination -->
      <% if @pagy.pages > 1 %>
        <div class="px-6 py-4 bg-white/5 border-t border-white/10">
          <%= pagy_nav(@pagy) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
