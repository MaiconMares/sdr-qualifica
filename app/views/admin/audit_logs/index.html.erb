<div class="min-h-screen bg-gradient-to-br from-blue-900 via-purple-900 to-indigo-900">
  <div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white mb-2">Logs de Auditoria</h1>
      <p class="text-white/70">Histórico de todas as ações no sistema</p>
    </div>

    <!-- Filters -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20 mb-8">
      <%= form_with url: admin_audit_logs_path, method: :get, local: true do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <label class="block text-white/70 text-sm font-medium mb-2">Ação</label>
            <select name="action" class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              <option value="">Todas</option>
              <% @actions.each do |action| %>
                <option value="<%= action %>" <%= params[:action] == action ? 'selected' : '' %>><%= AuditLog::ACTION_LABELS[action.to_sym] || action.humanize %></option>
              <% end %>
            </select>
          </div>
          <div>
            <label class="block text-white/70 text-sm font-medium mb-2">Usuário</label>
            <select name="user_id" class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              <option value="">Todos</option>
              <% @users.each do |user| %>
                <option value="<%= user.id %>" <%= params[:user_id] == user.id.to_s ? 'selected' : '' %>><%= user.name %></option>
              <% end %>
            </select>
          </div>
          <div>
            <label class="block text-white/70 text-sm font-medium mb-2">Data Início</label>
            <%= date_field_tag :start_date, params[:start_date], class: "w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>
          <div>
            <label class="block text-white/70 text-sm font-medium mb-2">Data Fim</label>
            <%= date_field_tag :end_date, params[:end_date], class: "w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>
        </div>
        <div class="mt-4 flex justify-end">
          <%= f.submit "Filtrar", class: "bg-blue-500 hover:bg-blue-600 text-white font-semibold px-6 py-2 rounded-xl transition-colors" %>
          <%= link_to "Limpar", admin_audit_logs_path, class: "ml-3 text-white/70 hover:text-white" %>
        </div>
      <% end %>
    </div>

    <!-- Audit Logs Table -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl border border-white/20 overflow-hidden">
      <table class="w-full">
        <thead class="bg-white/5">
          <tr>
            <th class="text-left text-white/70 font-medium px-6 py-4">Data/Hora</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Usuário</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Ação</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Entidade</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">IP</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
          <% @audit_logs.each do |log| %>
            <tr class="hover:bg-white/5 transition-colors">
              <td class="text-white/70 px-6 py-4"><%= l(log.created_at, format: :short) %></td>
              <td class="text-white px-6 py-4 font-medium"><%= log.user&.name || "Sistema" %></td>
              <td class="px-6 py-4">
                <span class="px-3 py-1 rounded-full text-sm font-medium <%= audit_action_class(log.action) %>">
                  <%= log.action_label %>
                </span>
              </td>
              <td class="text-white/70 px-6 py-4">
                <%= log.auditable_type %> #<%= log.auditable_id %>
              </td>
              <td class="text-white/70 px-6 py-4"><%= log.ip_address %></td>
              <td class="px-6 py-4">
                <%= link_to "Ver", admin_audit_log_path(log), class: "text-blue-400 hover:text-blue-300 text-sm font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <!-- Pagination -->
      <% if @pagy.pages > 1 %>
        <div class="px-6 py-4 bg-white/5 border-t border-white/10">
          <%= pagy_nav(@pagy) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
