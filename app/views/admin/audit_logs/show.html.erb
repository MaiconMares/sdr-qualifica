<div class="min-h-screen bg-gradient-to-br from-blue-900 via-purple-900 to-indigo-900">
  <div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">Detalhes do Log</h1>
        <p class="text-white/70">Informações detalhadas da ação</p>
      </div>
      <%= link_to "Voltar", admin_audit_logs_path, class: "bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-xl transition-colors" %>
    </div>

    <!-- Log Details -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
        <h2 class="text-xl font-bold text-white mb-4">Informações Gerais</h2>
        <div class="space-y-4">
          <div>
            <div class="text-white/60 text-sm mb-1">ID</div>
            <div class="text-white font-medium"><%= @audit_log.id %></div>
          </div>
          <div>
            <div class="text-white/60 text-sm mb-1">Data/Hora</div>
            <div class="text-white font-medium"><%= l(@audit_log.created_at, format: :long) %></div>
          </div>
          <div>
            <div class="text-white/60 text-sm mb-1">Usuário</div>
            <div class="text-white font-medium"><%= @audit_log.user&.name || "Sistema" %></div>
          </div>
          <div>
            <div class="text-white/60 text-sm mb-1">Ação</div>
            <div class="font-medium">
              <span class="px-3 py-1 rounded-full text-sm <%= audit_action_class(@audit_log.action) %>">
                <%= @audit_log.action.to_s.humanize %>
              </span>
            </div>
          </div>
          <div>
            <div class="text-white/60 text-sm mb-1">Endereço IP</div>
            <div class="text-white font-medium"><%= @audit_log.ip_address %></div>
          </div>
        </div>
      </div>

      <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
        <h2 class="text-xl font-bold text-white mb-4">Entidade Afetada</h2>
        <div class="space-y-4">
          <div>
            <div class="text-white/60 text-sm mb-1">Tipo</div>
            <div class="text-white font-medium"><%= @audit_log.auditable_type %></div>
          </div>
          <div>
            <div class="text-white/60 text-sm mb-1">ID</div>
            <div class="text-white font-medium"><%= @audit_log.auditable_id %></div>
          </div>
          <% if @audit_log.auditable %>
            <div>
              <div class="text-white/60 text-sm mb-1">Link</div>
              <%= link_to "Ver Entidade", polymorphic_path(@audit_log.auditable), class: "text-blue-400 hover:text-blue-300 text-sm font-medium" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Metadata -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
      <h2 class="text-xl font-bold text-white mb-4">Metadados</h2>
      <% if @audit_log.metadata.present? %>
        <pre class="bg-black/30 rounded-xl p-4 text-green-400 text-sm overflow-x-auto"><%= JSON.pretty_generate(@audit_log.metadata) %></pre>
      <% else %>
        <div class="text-white/50">Nenhum metadado disponível</div>
      <% end %>
    </div>
  </div>
</div>
