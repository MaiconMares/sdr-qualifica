<div class="min-h-screen bg-gradient-to-br from-blue-900 via-purple-900 to-indigo-900">
  <div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">Faixas de Faturamento</h1>
        <p class="text-white/70">Gerencie as faixas de faturamento dos leads</p>
      </div>
      <%= link_to "Nova Faixa", new_admin_revenue_range_path, class: "bg-blue-500 hover:bg-blue-600 text-white font-semibold px-6 py-3 rounded-xl transition-colors" %>
    </div>

    <!-- Revenue Ranges Table -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl border border-white/20 overflow-hidden">
      <table class="w-full">
        <thead class="bg-white/5">
          <tr>
            <th class="text-left text-white/70 font-medium px-6 py-4">Nome</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Valor Mínimo</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Valor Máximo</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Leads</th>
            <th class="text-left text-white/70 font-medium px-6 py-4">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
          <% @revenue_ranges.each do |range| %>
            <tr class="hover:bg-white/5 transition-colors">
              <td class="text-white px-6 py-4 font-medium"><%= range.name %></td>
              <td class="text-white/70 px-6 py-4"><%= number_to_currency(range.min_value, unit: "R$", separator: ",", delimiter: ".") %></td>
              <td class="text-white/70 px-6 py-4"><%= range.max_value ? number_to_currency(range.max_value, unit: "R$", separator: ",", delimiter: ".") : "Sem limite" %></td>
              <td class="text-white/70 px-6 py-4"><%= range.leads.count %></td>
              <td class="px-6 py-4">
                <div class="flex space-x-2">
                  <%= link_to "Ver", admin_revenue_range_path(range), class: "text-blue-400 hover:text-blue-300 text-sm font-medium" %>
                  <%= link_to "Editar", edit_admin_revenue_range_path(range), class: "text-white/70 hover:text-white text-sm font-medium" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
