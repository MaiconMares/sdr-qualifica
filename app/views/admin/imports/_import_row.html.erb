<tr class="hover:bg-white/5 transition-colors" id="import_row_<%= import.id %>">
  <td class="text-white px-6 py-4 font-medium"><%= import.filename %></td>
  <td class="px-6 py-4">
    <span class="px-3 py-1 rounded-full text-sm font-medium <%= import_status_class(import.status) %>">
      <%= import.status.upcase %>
    </span>
  </td>
  <td class="text-white/70 px-6 py-4">
    <% if import.total_rows.present? %>
      <%= import.processed_rows %> / <%= import.total_rows %>
      <% if import.failed_rows > 0 %>
        <span class="text-red-400">(<%= import.failed_rows %> erros)</span>
      <% end %>
    <% else %>
      -
    <% end %>
  </td>
  <td class="text-white/70 px-6 py-4"><%= l(import.created_at, format: :short) %></td>
  <td class="px-6 py-4">
    <div class="flex space-x-2">
      <%= link_to "Ver", admin_import_path(import), class: "text-blue-400 hover:text-blue-300 text-sm font-medium" %>
      <% if import.pending? %>
        <%= link_to "Cancelar", admin_import_path(import), 
            data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
            class: "text-red-400 hover:text-red-300 text-sm font-medium" %>
      <% end %>
    </div>
  </td>
</tr>
