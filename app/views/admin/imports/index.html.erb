<%# Upload Modal %>
<div id="upload-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50" aria-modal="true">
  <div class="bg-white rounded-2xl p-8 w-full max-w-lg mx-4 shadow-2xl">
    <div class="flex items-center justify-between mb-6">
      <h3 class="text-lg font-bold text-slate-900">Importar nova lista</h3>
      <button onclick="document.getElementById('upload-modal').classList.add('hidden')"
              class="text-slate-400 hover:text-slate-600 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <%= form_with url: admin_imports_path, method: :post, local: true, multipart: true do |f| %>
      <div class="border-2 border-dashed border-slate-200 rounded-xl p-8 text-center mb-5">
        <svg class="w-10 h-10 text-slate-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
        </svg>
        <p class="text-slate-500 text-sm mb-1">Arraste e solte ou escolha um arquivo</p>
        <p class="text-slate-400 text-xs mb-4">CSV, XLSX ou XLS</p>
        <input type="file" name="file" accept=".csv,.xlsx,.xls" id="file-input-modal" class="hidden"
               onchange="document.getElementById('file-label').textContent = this.files[0]?.name || 'Escolher arquivo'">
        <label for="file-input-modal"
               class="inline-flex items-center gap-2 bg-slate-100 hover:bg-slate-200 text-slate-700 text-sm font-medium px-4 py-2 rounded-lg cursor-pointer transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
          </svg>
          <span id="file-label">Escolher arquivo</span>
        </label>
      </div>

      <div class="flex gap-3">
        <button type="button"
                onclick="document.getElementById('upload-modal').classList.add('hidden')"
                class="flex-1 py-2.5 px-4 border border-slate-200 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-50 transition-colors">
          Cancelar
        </button>
        <%= f.submit "Importar lista",
              class: "flex-1 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold py-2.5 px-4 rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>

<%# Page Header %>
<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-green-600">Distribuição de Leads</h1>
    <p class="text-slate-500 text-sm mt-1">
      Importe a lista e distribua de forma equilibrada entre os SDRs, balanceando a
      quantidade por faixa de faturamento.
    </p>
  </div>
  <button onclick="document.getElementById('upload-modal').classList.remove('hidden')"
          class="flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors flex-shrink-0">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
    </svg>
    Importar nova lista
  </button>
</div>

<% if @latest_import %>
  <%# Recent Import File Card %>
  <div class="bg-white rounded-xl border border-slate-200 px-5 py-4 mb-6 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 bg-green-50 rounded-lg flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
      </div>
      <div>
        <div class="font-semibold text-slate-900 text-sm"><%= @latest_import.filename %></div>
        <div class="text-slate-400 text-xs mt-0.5">
          <%= @total_leads %> leads importados
          · <%= @total_ranges %> faixas detectadas
          · <%= time_ago_pt(@latest_import.created_at) %>
        </div>
      </div>
    </div>
    <div class="flex items-center gap-5">
      <span class="flex items-center gap-1.5 text-green-600 text-sm font-medium">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"/>
        </svg>
        Validado
      </span>
      <button onclick="document.getElementById('upload-modal').classList.remove('hidden')"
              class="text-slate-500 hover:text-slate-800 text-sm font-medium transition-colors">
        Trocar arquivo
      </button>
    </div>
  </div>
<% end %>

<%# Stats Cards %>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Total de Leads</div>
    <div class="text-3xl font-bold text-slate-900"><%= @total_leads %></div>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">SDRs Ativos</div>
    <div class="text-3xl font-bold text-slate-900"><%= @active_sdrs.count %></div>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Média por SDR</div>
    <div class="text-3xl font-bold text-green-600"><%= @avg_per_sdr %></div>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Faixas</div>
    <div class="text-3xl font-bold text-slate-900"><%= @total_ranges %></div>
  </div>
</div>

<% if @active_sdrs.any? && @revenue_ranges.any? %>
  <%# Distribution Preview %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-6 py-4 flex items-center justify-between border-b border-slate-100">
      <h2 class="font-bold text-slate-900">Prévia da distribuição</h2>
      <span class="flex items-center gap-1.5 text-green-600 text-xs font-medium">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"/>
        </svg>
        Equilíbrio ótimo - variação a 1 lead por faixa
      </span>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-100 bg-slate-50">
            <th class="text-left text-[10px] font-bold text-slate-400 uppercase tracking-widest px-6 py-3 w-48">SDR</th>
            <% @revenue_ranges.each do |rr| %>
              <th class="text-center text-[10px] font-bold text-slate-400 uppercase tracking-widest px-4 py-3">
                <%= rr.name.upcase %>
              </th>
            <% end %>
            <th class="text-center text-[10px] font-bold text-slate-400 uppercase tracking-widest px-4 py-3">TOTAL</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @active_sdrs.each do |sdr| %>
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-6 py-3.5">
                <div class="flex items-center gap-2.5">
                  <div class="w-7 h-7 <%= user_avatar_color(sdr.id) %> rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                    <%= user_initials(sdr.name) %>
                  </div>
                  <span class="font-medium text-slate-800"><%= sdr.name %></span>
                </div>
              </td>
              <% @revenue_ranges.each do |rr| %>
                <td class="text-center text-slate-600 px-4 py-3.5"><%= @distribution[sdr.id][rr.id] %></td>
              <% end %>
              <td class="text-center font-semibold text-green-600 px-4 py-3.5"><%= @sdr_totals[sdr] %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr class="border-t-2 border-slate-200 bg-slate-50">
            <td class="px-6 py-3.5 text-[10px] font-bold text-slate-400 uppercase tracking-widest">Total por Faixa</td>
            <% @revenue_ranges.each do |rr| %>
              <td class="text-center font-bold text-slate-800 px-4 py-3.5"><%= @range_totals[rr] %></td>
            <% end %>
            <td class="text-center font-bold text-slate-900 px-4 py-3.5"><%= @total_leads %></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <%# Action Buttons %>
    <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-end gap-3">
      <%= button_to redistribute_admin_leads_path, method: :post,
            class: "px-5 py-2.5 border border-slate-200 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-50 transition-colors",
            data: { turbo_confirm: "Isso irá redistribuir todos os leads entre os SDRs. Continuar?" } do %>
        Reconfigurar
      <% end %>
      <%= button_to redistribute_admin_leads_path, method: :post,
            class: "flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors",
            data: { turbo_confirm: "Confirmar a distribuição de leads entre os SDRs?" } do %>
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"/>
        </svg>
        Confirmar distribuição
      <% end %>
    </div>
  </div>

<% else %>
  <%# Empty State %>
  <div class="bg-white rounded-xl border border-slate-200 p-16 text-center">
    <div class="w-14 h-14 bg-slate-100 rounded-xl flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
    </div>
    <h3 class="font-semibold text-slate-900 mb-2">Nenhuma lista importada</h3>
    <p class="text-slate-500 text-sm mb-6">Importe uma lista de leads para visualizar a prévia da distribuição.</p>
    <button onclick="document.getElementById('upload-modal').classList.remove('hidden')"
            class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
      </svg>
      Importar nova lista
    </button>
  </div>
<% end %>
