<div class="min-h-screen bg-gradient-to-br from-blue-900 via-purple-900 to-indigo-900">
  <div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">Relatórios</h1>
        <p class="text-white/70">Estatísticas e métricas do sistema</p>
      </div>
      <div class="flex space-x-3">
        <%= link_to export_csv_admin_reports_path(report_type: "overall"), class: "bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-xl transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 inline mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Exportar CSV
        <% end %>
        <%= link_to export_xlsx_admin_reports_path(report_type: "overall"), class: "bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-xl transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 inline mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Exportar XLSX
        <% end %>
      </div>
    </div>

    <!-- Overview Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
        <div class="text-white/60 text-sm font-medium mb-2">Total de Chamadas</div>
        <div class="text-white text-3xl font-bold"><%= @statistics[:total_calls] %></div>
        <div class="text-white/50 text-sm mt-2">Chamadas/dia: <%= @statistics[:calls_per_day] %></div>
      </div>
      <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
        <div class="text-white/60 text-sm font-medium mb-2">Duração Média</div>
        <div class="text-white text-3xl font-bold"><%= format_duration(@statistics[:average_call_duration]) %></div>
        <div class="text-white/50 text-sm mt-2">Por chamada</div>
      </div>
      <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
        <div class="text-white/60 text-sm font-medium mb-2">Total de Pausas</div>
        <div class="text-white text-3xl font-bold"><%= @statistics[:total_pauses] %></div>
        <div class="text-white/50 text-sm mt-2">Duração média: <%= format_duration(@statistics[:average_pause_duration]) %></div>
      </div>
      <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
        <div class="text-white/60 text-sm font-medium mb-2">Leads por Status</div>
        <div class="text-white text-3xl font-bold"><%= @statistics[:leads_by_status].values.sum %></div>
        <div class="text-white/50 text-sm mt-2">Total de leads</div>
      </div>
    </div>

    <!-- SDR Statistics -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20 mb-8">
      <h2 class="text-xl font-bold text-white mb-4">Estatísticas por SDR</h2>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-white/5">
            <tr>
              <th class="text-left text-white/70 font-medium px-4 py-3">SDR</th>
              <th class="text-left text-white/70 font-medium px-4 py-3">Chamadas</th>
              <th class="text-left text-white/70 font-medium px-4 py-3">Duração Média</th>
              <th class="text-left text-white/70 font-medium px-4 py-3">Pausas</th>
              <th class="text-left text-white/70 font-medium px-4 py-3">Tempo de Pausa</th>
              <th class="text-left text-white/70 font-medium px-4 py-3">Conversão</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/10">
            <% @sdr_statistics.each do |stat| %>
              <tr class="hover:bg-white/5 transition-colors">
                <td class="text-white px-4 py-3 font-medium"><%= stat[:user_name] %></td>
                <td class="text-white/70 px-4 py-3"><%= stat[:total_calls] %></td>
                <td class="text-white/70 px-4 py-3"><%= format_duration(stat[:average_call_duration]) %></td>
                <td class="text-white/70 px-4 py-3"><%= stat[:total_pauses] %></td>
                <td class="text-white/70 px-4 py-3"><%= format_duration(stat[:total_pause_duration]) %></td>
                <td class="text-white/70 px-4 py-3"><%= stat[:conversion_rate] %>%</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Revenue Range Statistics -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20 mb-8">
      <h2 class="text-xl font-bold text-white mb-4">Distribuição por Faixa de Faturamento</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <% @revenue_statistics.each do |stat| %>
          <div class="bg-white/5 rounded-xl p-4">
            <div class="text-white/60 text-sm mb-1"><%= stat[:revenue_range] %></div>
            <div class="text-white text-2xl font-bold"><%= stat[:count] %></div>
            <div class="text-white/50 text-sm mt-1">Duração média: <%= format_duration(stat[:average_call_duration]) %></div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Conversion by Status -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20 mb-8">
      <h2 class="text-xl font-bold text-white mb-4">Conversão por Status</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4">
        <% @statistics[:leads_by_status].each do |status, count| %>
          <div class="bg-white/5 rounded-xl p-4">
            <div class="text-white/60 text-sm mb-1"><%= status.humanize %></div>
            <div class="text-white text-2xl font-bold"><%= count %></div>
            <div class="text-white/50 text-sm mt-1">
              <%= ((count.to_f / @statistics[:leads_by_status].values.sum) * 100).round(1) %>%
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Leaderboard -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20 mb-8">
      <h2 class="text-xl font-bold text-white mb-4">Leaderboard</h2>
      <div class="space-y-3">
        <% @leaderboard.each_with_index do |stat, index| %>
          <div class="flex items-center justify-between py-3 border-b border-white/10 last:border-0">
            <div class="flex items-center space-x-4">
              <div class="w-8 h-8 rounded-full flex items-center justify-center <%= index < 3 ? 'bg-yellow-500 text-white' : 'bg-white/10 text-white/70' %> font-bold">
                <%= index + 1 %>
              </div>
              <div>
                <div class="text-white font-medium"><%= stat[:user_name] %></div>
                <div class="text-white/50 text-sm"><%= stat[:total_calls] %> chamadas</div>
              </div>
            </div>
            <div class="text-white font-bold"><%= stat[:conversion_rate] %>% conversão</div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Daily Statistics -->
    <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20">
      <h2 class="text-xl font-bold text-white mb-4">Estatísticas Diárias (Últimos 7 dias)</h2>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-white/5">
            <tr>
              <th class="text-left text-white/70 font-medium px-4 py-3">Data</th>
              <th class="text-left text-white/70 font-medium px-4 py-3">Chamadas</th>
              <th class="text-left text-white/70 font-medium px-4 py-3">Duração Média</th>
              <th class="text-left text-white/70 font-medium px-4 py-3">Pausas</th>
              <th class="text-left text-white/70 font-medium px-4 py-3">Tempo de Pausa</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/10">
            <% @daily_statistics.each do |stat| %>
              <tr class="hover:bg-white/5 transition-colors">
                <td class="text-white px-4 py-3 font-medium"><%= l(stat[:date], format: :short) %></td>
                <td class="text-white/70 px-4 py-3"><%= stat[:total_calls] %></td>
                <td class="text-white/70 px-4 py-3"><%= format_duration(stat[:average_call_duration]) %></td>
                <td class="text-white/70 px-4 py-3"><%= stat[:total_pauses] %></td>
                <td class="text-white/70 px-4 py-3"><%= format_duration(stat[:total_pause_duration]) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
