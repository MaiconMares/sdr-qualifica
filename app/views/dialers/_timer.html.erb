<div class="bg-white rounded-xl border border-slate-200 px-6 py-5"
     data-controller="timer"
     data-timer-url-value="<%= timer_state_dialer_path %>"
     data-timer-work-session-id-value="<%= work_session&.id %>">
  <div class="flex items-center gap-1.5 text-slate-400 text-xs font-semibold uppercase tracking-widest mb-2">
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    Tempo de Trabalho
  </div>
  <div class="text-4xl font-bold font-mono text-slate-900 tracking-wider mb-1" data-timer-target="display">
    00:00:00
  </div>
  <div class="flex items-center gap-1.5" data-timer-target="status">
    <span class="w-2 h-2 rounded-full bg-slate-300 inline-block"></span>
    <span class="text-slate-400 text-xs">
      <%= work_session&.paused? ? "Pausado" : (work_session&.active? ? "Em andamento" : "Aguardando") %>
    </span>
  </div>
</div>
