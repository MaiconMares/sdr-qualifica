<div class="relative" data-controller="pause-modal">
  <button
    type="button"
    data-action="click->pause-modal#open"
    class="flex items-center gap-2 bg-white border border-slate-200 hover:border-slate-300 text-slate-700 font-semibold px-5 py-3 rounded-xl transition-all duration-200 shadow-sm hover:shadow"
  >
    <svg class="w-4 h-4 text-slate-500" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zM7 8a1 1 0 012 0v4a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
    </svg>
    Pausar
  </button>

  <div
    data-pause-modal-target="modal"
    class="hidden fixed inset-0 bg-black/40 backdrop-blur-sm z-50 flex items-center justify-center"
  >
    <div class="bg-white rounded-2xl p-6 w-full max-w-md mx-4 shadow-2xl">
      <h3 class="text-lg font-bold text-slate-800 mb-4">Motivo da Pausa</h3>

      <div class="space-y-2 mb-4">
        <% pause_reasons.each do |key, label| %>
          <label class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 hover:border-green-400 cursor-pointer transition-colors">
            <%= radio_button_tag :reason, key, false,
                  class: "w-4 h-4 text-green-600",
                  data: { action: "change->pause-modal#selectReason" } %>
            <span class="text-slate-700 text-sm"><%= label %></span>
          </label>
        <% end %>
      </div>

      <div id="pause_description_field" class="hidden mb-4">
        <label class="block text-sm font-medium text-slate-700 mb-1">Descrição (obrigatório)</label>
        <textarea
          name="description"
          rows="3"
          class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-green-500 focus:border-transparent"
          placeholder="Descreva o motivo da pausa..."
        ></textarea>
      </div>

      <div class="flex gap-3">
        <button
          type="button"
          data-action="click->pause-modal#close"
          class="flex-1 px-4 py-2.5 border border-slate-200 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50 transition-colors"
        >
          Cancelar
        </button>
        <%= button_to "Confirmar Pausa",
          pause_dialer_path,
          method: :post,
          data: {
            turbo_stream: true,
            action: "click->pause-modal#submit"
          },
          class: "flex-1 px-4 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded-lg transition-colors"
        %>
      </div>
    </div>
  </div>
</div>
