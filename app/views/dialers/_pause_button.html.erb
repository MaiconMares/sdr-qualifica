<div class="relative">
  <button 
    type="button"
    data-action="click->pause-modal#open"
    class="bg-yellow-500 hover:bg-yellow-600 text-white font-semibold px-6 py-3 rounded-xl transition-all duration-200 flex items-center space-x-2 shadow-lg hover:shadow-xl"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zM7 8a1 1 0 012 0v4a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
    </svg>
    <span>Pausar</span>
  </button>

  <!-- Pause Modal -->
  <div 
    data-pause-modal-target="modal"
    class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center"
  >
    <div class="bg-white rounded-2xl p-6 w-full max-w-md mx-4 shadow-2xl" data-controller="pause-modal">
      <h3 class="text-xl font-bold text-gray-800 mb-4">Motivo da Pausa</h3>
      
      <div class="space-y-3 mb-4">
        <% pause_reasons.each do |key, label| %>
          <label class="flex items-center p-3 rounded-lg border-2 border-gray-200 hover:border-blue-500 cursor-pointer transition-colors">
            <%= radio_button_tag :reason, key, false, class: "w-4 h-4 text-blue-600", data: { action: "change->pause-modal#selectReason" } %>
            <span class="ml-3 text-gray-700"><%= label %></span>
          </label>
        <% end %>
      </div>

      <div id="pause_description_field" class="hidden mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-2">Descrição (obrigatório)</label>
        <textarea 
          name="description" 
          rows="3" 
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          placeholder="Descreva o motivo da pausa..."
        ></textarea>
      </div>

      <div class="flex space-x-3">
        <button 
          type="button"
          data-action="click->pause-modal#close"
          class="flex-1 px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
        >
          Cancelar
        </button>
        <%= button_to 
          "Confirmar Pausa",
          pause_dialer_path,
          method: :post,
          data: { 
            turbo_stream: true,
            action: "click->pause-modal#submit"
          },
          class: "flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
        %>
      </div>
    </div>
  </div>
</div>
