            <%= current_user.role.upcase %>
          </span>
        </div>
        <%= button_to "Sair", destroy_user_session_path, method: :delete, 
            class: "bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-lg transition-colors text-sm font-medium" %>
      </div>
    </div>
  </div>
</nav>
