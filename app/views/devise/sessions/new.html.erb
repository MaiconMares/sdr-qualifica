<div class="min-h-screen flex">
  <!-- Left Panel -->
  <div class="hidden lg:flex lg:w-1/2 bg-[#0a1628] relative overflow-hidden flex-col p-10">
    <!-- Background glow -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-green-600/15 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-2/3 right-0 w-64 h-64 bg-green-800/10 rounded-full blur-2xl pointer-events-none"></div>

    <!-- Logo -->
    <div class="flex items-center gap-3 relative z-10">
      <div class="w-10 h-10 bg-green-600 rounded-xl flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0
                   3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946
                   3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138
                   3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806
                   3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438
                   3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
        </svg>
      </div>
      <span class="text-white font-semibold text-lg">SDR Qualificador</span>
    </div>

    <!-- Content -->
    <div class="flex-1 flex flex-col justify-center relative z-10">
      <div class="inline-flex items-center gap-2 border border-green-500/40 text-green-400 text-xs px-3 py-1.5 rounded-full mb-8 w-fit">
        <span class="w-1.5 h-1.5 bg-green-400 rounded-full"></span>
        Módulo SDR · Discador
      </div>

      <h1 class="text-white text-4xl font-bold leading-tight mb-5">
        Qualifique cada lead<br>com ritmo e clareza.
      </h1>

      <p class="text-slate-400 text-sm leading-relaxed max-w-sm">
        Conduza sua fila de ligações, registre o resultado em um clique e mantenha o pipeline sempre atualizado no Kanban.
      </p>
    </div>

    <!-- Feature List -->
    <div class="relative z-10 flex items-center gap-6 text-slate-400 text-sm">
      <% [["Fila inteligente"], ["Tempo monitorado"], ["Kanban automático"]].each do |item| %>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-green-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          <%= item[0] %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Right Panel -->
  <div class="flex-1 flex items-center justify-center bg-white p-8">
    <div class="w-full max-w-sm">
      <!-- Flash messages -->
      <% if notice %>
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 text-sm">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">
          <%= alert %>
        </div>
      <% end %>

      <h2 class="text-2xl font-bold text-slate-900 mb-1">Entrar</h2>
      <p class="text-green-600 text-sm mb-7">Acesse o painel de discagem e qualificação.</p>

      <!-- Access Type Toggle -->
      <div class="mb-6">
        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Tipo de Acesso</label>
        <div class="flex gap-1 bg-slate-100 p-1 rounded-lg">
          <button type="button" id="tab-sdr" onclick="setLoginTab('sdr')"
                  class="flex-1 flex items-center justify-center gap-2 py-2 px-3 rounded-md text-sm font-medium bg-white text-slate-800 shadow-sm transition-all">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13
                       a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0
                       01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            SDR
          </button>
          <button type="button" id="tab-admin" onclick="setLoginTab('admin')"
                  class="flex-1 flex items-center justify-center gap-2 py-2 px-3 rounded-md text-sm font-medium text-slate-500 transition-all">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            Admin
          </button>
        </div>
      </div>

      <!-- Login Form -->
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4 mb-5">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">E-mail</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <%= f.email_field :email, autofocus: true, autocomplete: "email",
                    id: "user_email_field",
                    class: "w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-lg text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent text-sm",
                    placeholder: "voce@sdrqualificador.com.br" %>
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="block text-sm font-medium text-slate-700">Senha</label>
              <%= link_to "Esqueceu a senha?", new_user_password_path,
                    class: "text-sm text-green-600 hover:text-green-700 font-medium" %>
            </div>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
              </div>
              <%= f.password_field :password, autocomplete: "current-password",
                    class: "w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-lg text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent text-sm",
                    placeholder: "••••••••" %>
            </div>
          </div>
        </div>

        <%= f.submit "Entrar",
              class: "w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-3 px-4 rounded-lg transition-colors cursor-pointer text-sm" %>
      <% end %>

      <p class="text-center text-xs text-slate-400 mt-6">SDR Qualificador · Discador SDR — uso interno</p>
    </div>
  </div>
</div>

<script>
  function setLoginTab(tab) {
    const sdrBtn   = document.getElementById('tab-sdr');
    const adminBtn = document.getElementById('tab-admin');
    const activeClasses   = ['bg-white', 'text-slate-800', 'shadow-sm'];
    const inactiveClasses = ['text-slate-500'];

    if (tab === 'sdr') {
      activeClasses.forEach(c => sdrBtn.classList.add(c));
      inactiveClasses.forEach(c => sdrBtn.classList.remove(c));
      inactiveClasses.forEach(c => adminBtn.classList.add(c));
      activeClasses.forEach(c => adminBtn.classList.remove(c));
    } else {
      activeClasses.forEach(c => adminBtn.classList.add(c));
      inactiveClasses.forEach(c => adminBtn.classList.remove(c));
      inactiveClasses.forEach(c => sdrBtn.classList.add(c));
      activeClasses.forEach(c => sdrBtn.classList.remove(c));
    }
  }
</script>
